{
  "name": "handbook",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "cd apps/web && bun run dev",
    "dev:api": "cd apps/api && bun run dev",
    "build:web": "cd apps/web && bun run build",
    "build:api": "cd apps/api && bun run build",
    "typecheck:web": "cd apps/web && bun run typecheck",
    "typecheck:api": "cd apps/api && bun run typecheck",
    "backfill:entry-language": "cd apps/api && bunx tsx src/scripts/backfill-entry-language.ts",
    "backfill:entry-prompts": "cd apps/api && bunx tsx src/scripts/backfill-entry-prompts.ts",
    "import:longform-reference": "cd apps/api && bunx tsx src/scripts/import-longform-reference.ts",
    "db:check": "cd packages/db && bun run check",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run packages/db/src/migrate.ts",
    "lint": "echo \"lint scripts not wired yet\"",
    "test": "echo \"test scripts not wired yet\""
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.4"
  }
}
