# API runtime
PORT=8787

# PostgreSQL
DATABASE_URL=postgres://handbook:handbook@127.0.0.1:54329/handbook

# Local file storage root
UPLOAD_DIR=ARTIFACTS/runtime/uploads

# AI provider
# Supported:
# - mock
# - openai-compatible
# - anthropic
# - gemini
# - litellm
AI_PROVIDER=mock
AI_MODEL=gpt-4.1-mini
AI_API_KEY=
AI_BASE_URL=

# Optional provider-specific overrides
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-7-sonnet-latest
GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_NAME=gemini-2.5-flash
LITELLM_API_KEY=
LITELLM_BASE_URL=
LITELLM_MODEL=gpt-4.1-mini
